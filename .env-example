# Copy to .env and fill with real values. NEVER commit .env.
# Secrets come from the environment only (PRD §15, ADR-006).

# --- LLM provider API key (only if llm.provider != none) ---
LLM_API_KEY=dummy-llm-api-key

# --- MCP bearer token for the inter-group / cloud match (sent out of band) ---
MCP_AUTH_TOKEN=dummy-mcp-bearer-token

# --- Peer team's MCP token (bonus match), if they issue you one ---
PEER_MCP_AUTH_TOKEN=dummy-peer-token

# --- Gmail OAuth ---
# credentials.json and token.json are FILES (git-ignored), produced by the
# Google OAuth flow; they are not stored here. See docs/PRD_gmail_reporting.md.
