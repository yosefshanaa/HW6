# --- Secrets / credentials (NEVER commit) ---
.env
.env.*
!.env-example
credentials.json
token.json
client_secret*.json
*.key
*.pem

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# --- Virtual envs / uv ---
.venv/
venv/
# note: uv.lock SHOULD be committed (do not ignore it)

# --- Tooling caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# --- Runtime logs / results (keep dirs via .gitkeep, ignore contents) ---
logs/
results/*.jsonl
results/*.json
results/*.html
results/*/
!results/.gitkeep

# --- IDE / OS / tooling ---
.vscode/
.idea/
.DS_Store
Thumbs.db
.claude/settings.local.json

# iPhone photo originals (committed as downsized JPGs in assets/)
*.HEIC
